# cPanel Passenger — Node.js App Configuration
# Passenger handles ALL requests and passes them to Node.js automatically.
# DO NOT add RewriteRules pointing to server.js — that serves it as a static file!

PassengerEnabled on
PassengerNodejs /usr/local/bin/node
PassengerStartupFile server.js
PassengerAppRoot /home/connectf/medec_nepal
PassengerAppType node
